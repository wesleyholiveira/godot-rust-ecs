[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.6
reloadable = true

[libraries]
linux.debug.x86_64 = "res://../rust/target/debug/libgodot_bevy_ecs_demo.so"
linux.release.x86_64 = "res://../rust/target/release/libgodot_bevy_ecs_demo.so"
windows.debug.x86_64 = "res://../rust/target/debug/godot_bevy_ecs_demo.dll"
windows.release.x86_64 = "res://../rust/target/release/godot_bevy_ecs_demo.dll"
macos.debug = "res://../rust/target/debug/libgodot_bevy_ecs_demo.dylib"
macos.release = "res://../rust/target/release/libgodot_bevy_ecs_demo.dylib"
macos.debug.arm64 = "res://../rust/target/debug/libgodot_bevy_ecs_demo.dylib"
macos.release.arm64 = "res://../rust/target/release/libgodot_bevy_ecs_demo.dylib"
